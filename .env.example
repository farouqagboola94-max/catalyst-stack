# CatalystOS — the terminal. Copy to .env and fill in. Never commit .env.

# ── The brain for the Skills Engine (POST /api/skills/{id}/run) ──
# An OpenAI-compatible chat endpoint. Three easy options:
#
#  1) Straight to a free provider (fastest):
#       OpenRouter:  https://openrouter.ai/api/v1   (key: sk-or-v1-...)
#       NVIDIA NIM:  https://integrate.api.nvidia.com/v1   (key: nvapi-...)
#       DeepSeek:    https://api.deepseek.com/v1    (key: sk-...)
#  2) Through the local model-router (modules/model-router) once it's running.
#
# Leave CATALYST_LLM_KEY blank to keep the engine in safe dry-run mode
# (it shows what it WOULD send instead of calling out).
CATALYST_LLM_BASE=https://openrouter.ai/api/v1
CATALYST_LLM_KEY=
CATALYST_LLM_MODEL=deepseek/deepseek-chat

# ── Video lane (ComfyUI) ──
COMFYUI_API_BASE=http://127.0.0.1:8188
# COMFYUI_CLOUD_BASE=            # rented RunPod/Vast endpoint for switchboard fallback
