# CatalystOS Model Router — keys live here, never in config.json
# Copy this to a real .env, fill in your own keys, then source it before running ccr.
#   cp .env.example .env
#   nano .env
#   source .env

# OpenRouter — one key, every model (Gemini, DeepSeek, GLM, Claude). Get it: https://openrouter.ai/keys
export OPENROUTER_API_KEY=""

# DeepSeek direct — cheapest for default + reasoning. Get it: https://platform.deepseek.com
export DEEPSEEK_API_KEY=""

# Google Gemini direct — has a real free tier for background/long context. Get it: https://aistudio.google.com/apikey
export GEMINI_API_KEY=""

# Anthropic direct — kept for high stakes work only (see the risk rule in README). Get it: https://console.anthropic.com
export ANTHROPIC_API_KEY=""
